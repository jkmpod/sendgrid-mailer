# SendGrid API key — get one at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity (must be verified in SendGrid)
FROM_EMAIL=noreply@example.com
FROM_NAME="Example Sender"

# Batching — how many recipients per API call and delay between calls
MAX_BATCH_SIZE=1000
RATE_DELAY_MS=100

# Server port
PORT=8080

# Test mode — set to true to send only to TEST_EMAILS instead of real recipients
TEST_MODE=true
TEST_EMAILS=dev1@example.com,dev2@example.com

# SendGrid Activity Feed endpoint (override only for regional or sandbox endpoints)
# SENDGRID_MESSAGES_URL=https://api.sendgrid.com/v3/messages

# Maximum upload size in MB (default 10)
# MAX_UPLOAD_SIZE_MB=10
